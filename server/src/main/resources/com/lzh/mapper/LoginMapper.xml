<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.lzh.mapper.LoginMapper">


    <select id="selectByStuId" resultType="com.lzh.pojo.entity.Student">
        select id ,password ,stu_id,name ,schedule_bitmap from student where stu_id = #{stuId}
    </select>
    <select id="getScheduleBitmapById" parameterType="java.lang.Long">
        select schedule_bitmap from student where id = #{id}
    </select>
</mapper>